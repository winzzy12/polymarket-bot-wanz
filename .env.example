# ══════════════════════════════════════════════════════════════════
# polymarket-bot — Environment Configuration
# ══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# WALLET SETUP
# ─────────────────────────────────────────────
PRIVATE_KEY=0xYOUR_EOA_PRIVATE_KEY_HERE
PROXY_WALLET_ADDRESS=0xYOUR_PROXY_WALLET_ADDRESS_HERE

# ─────────────────────────────────────────────
# POLYGON RPC
# ─────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon.lava.build

# ─────────────────────────────────────────────
# POLYMARKET API CREDENTIALS
# ─────────────────────────────────────────────
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ─────────────────────────────────────────────
# PROXY (optional)
# ─────────────────────────────────────────────
PROXY_URL=

# ─────────────────────────────────────────────
# MODE
# ─────────────────────────────────────────────
DRY_RUN=true

# ─────────────────────────────────────────────
# WEB DASHBOARD
# ─────────────────────────────────────────────
WEB_PORT=3000
WEB_USERNAME=admin
WEB_PASSWORD=polymarket123
